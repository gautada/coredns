.:53 {
    health :8080
    ready :8181
    prometheus :9153

    # kubernetes cluster.local in-addr.arpa ip6.arpa {
    #     pods insecure
    #     fallthrough in-addr.arpa ip6.arpa
    # }

    file /etc/container/zone.local example.local
    file /etc/container/zone.tld example.tld

    forward . tls://1.1.1.1 tls://1.0.0.1 {
        tls_servername cloudflare-dns.com
        health_check 30s
    }

    log
    errors
    cache 60
    loop
    reload 30s
}
